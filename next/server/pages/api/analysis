// Archivo: pages/api/analysis.js (Versión Corregida)

export default async function handler(req, res) {
  // Verificamos que sea una solicitud GET
  if (req.method !== 'GET') {
    res.setHeader('Allow', ['GET']);
    return res.status(405).end(`Method ${req.method} Not Allowed`);
  }

  try {
    // --- INICIO DE LA LÓGICA DE NEGOCIO ---
    
    // En un proyecto real, aquí nos conectaríamos a una base de datos.
    // Esta conexión debe estar optimizada.
    const stockData = [{ sku: '649701', stock: 50, costo: 5500, link: 'http://ejemplo.com/p1' }];
    const salesData = [{ sku: '649701', unidades: 75, fecha: '2025-08-10', precio: 19990 }];
    const transitData = [{ sku: '649701', cantidad: 100, fechaLlegada: '2025-09-15' }];
    const purchaseData = [{ sku: '649701', fechaLlegada: '2025-08-01' }];

    // Esta función simula el análisis. La clave es que el procesamiento no exceda el límite de tiempo.
    function runFullAnalysis(products) {
      return products.map(product => {
        // 1. CÁLCULO DE VENTA DIARIA (simplificado para la demo)
        const ventaDiaria = 2.5;

        // 2. LÓGICA DE COMPRA PREDICTIVA
        const tiempoEntrega = 90;
        const consumoProyectado = ventaDiaria * tiempoEntrega;
        const transitosPorLlegar = transitData.find(t => t.sku === product.sku)?.cantidad || 0;
        const stockProyectado = (product.stock + transitosPorLlegar) - consumoProyectado;
        const stockObjetivo = ventaDiaria * 90;
        const cantidadSugerida = Math.max(0, Math.round(stockObjetivo - stockProyectado));

        // 3. CLASIFICACIÓN DE INVENTARIO GRANULAR
        const diasCobertura = product.stock / ventaDiaria;
        let estadoInventario = 'CRÍTICO';
        if (diasCobertura >= 90 && diasCobertura <= 120) estadoInventario = 'SALUDABLE';
        else if (diasCobertura > 120 && diasCobertura <= 180) estadoInventario = 'STOCK DE 4 A 6 MESES';
        else if (diasCobertura > 180) estadoInventario = 'STOCK SUPERIOR A 6 MESES';
        // (aquí irían los otros estados: ALTO, MEDIO)

        // 4. LÓGICA DE PRECIO DE REFERENCIA
        const ultimaLlegada = purchaseData.find(p => p.sku === product.sku)?.fechaLlegada;
        const precioMinPostArribo = salesData.find(s => s.sku === product.sku)?.precio || 0;
        const fechaPrecioMin = salesData.find(s => s.sku === product.sku)?.fecha || null;

        return {
          sku: product.sku,
          descripcion: `Descripción para ${product.sku}`,
          ...product,
          ventaDiaria,
          cantidadSugerida,
          estadoInventario,
          precioMinPostArribo,
          fechaPrecioMin
        };
      });
    }
    
    const analysisResults = runFullAnalysis(stockData);
    
    // --- FIN DE LA LÓGICA DE NEGOCIO ---

    // Enviamos una respuesta exitosa con los resultados.
    return res.status(200).json({ results: analysisResults });

  } catch (error) {
    // Si algo falla dentro del bloque 'try', el error será capturado aquí.
    console.error('Error en la función de API:', error); // Esto se vería en los logs de Netlify
    return res.status(500).json({ error: 'Hubo un error interno en el servidor al procesar los datos.' });
  }
}
